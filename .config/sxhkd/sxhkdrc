super + {shift + k, k}
	xinput set-prop 10 "libinput Disable While Typing Enabled" {0, 1} 

#
#Запуск приложений
#

super + Return
	alacritty

super + d
	rofi -show drun -theme .config/rofi/themes/newtheme.rasi

super + shift + s
	flameshot gui

super + {p, b, c, v, x, f, w, l, m}
	{power.sh, firefox, qalculate, pavucontrol, xfce4-power-manager-settings, thunar, nitrogen, i3lock-fancy, arandr}
	
#
#Управление системой
#

XF86AudioRaiseVolume
	pamixer --allow-boost --set-limit 150 -i 10

XF86AudioLowerVolume
	pamixer --allow-boost -d 10

XF86AudioMute
	pamixer -t

XF86MonBrightnessUp
	brightnessctl s 10%+

XF86MonBrightnessDown
	brightnessctl s 10%-

