#
#Управление bspwm
#

super + alt + {q,r}
	bspc {quit,wm -r} #перезагрузить выйти

alt + {t,s, f}
	bspc node -t {tiled,floating,fullscreen}

super + {_, shift} + q
	bspc node -{c,k} #закрыть убить

super + Escape
	pkill -USR1 -x sxhkd #перезагрузить хоткеи
	
#
#Управление окнами
#

super + {_, shift +} + {_,ctrl +} + {1-9,0}
	bspc {desktop -f,node -d} {eDP-1:,HDMI-1:}'^{1-9,10}' 

#super + {_, shift +} + {1-9,0}
#	bspc {desktop -f,node -d} '^{1-9,10}' 
	
super {_, shift +} {Left,Up,Right,Down}
	bspc node {-f,-s} {west,north,east,south}

super + ctrl + {Left,Up,Right,Down}
	bspc node -z {left -100 0,top 0 -100,right 100 0,bottom 0 100}

super + alt + {Left,Up,Right,Down}
	bspc node -z {right -100 0,bottom 0 -100,left 100 0,top 0 100}

ctrl + alt + {Left,Up,Right,Down}
	bspc node -p {west,north,east,south}

